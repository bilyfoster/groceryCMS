# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=brochure_cms
POSTGRES_USER=cms_user
POSTGRES_PASSWORD=change-me

# Spring Boot
SPRING_PROFILES_ACTIVE=dev
JWT_SECRET=change-me-to-a-512-bit-hex-secret-at-least-64-chars-long-for-hs256
JWT_EXPIRY_DAYS=7
APP_BASE_URL=http://localhost:3000
APP_MEDIA_ROOT=./media
APP_TENANT_HEADER_ENABLED=true

# CORS (required in production so the public domain can call the API)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# SMTP (optional in dev — magic link emails require SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=noreply@localhost

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api
BACKEND_URL=http://localhost:8080

# hCaptcha (optional — contact form)
HCAPTCHA_SECRET=
NEXT_PUBLIC_HCAPTCHA_SITEKEY=

# -----------------------------------------------------------------------------
# Production example for brazen.1lpro.com (uses the existing Traefik reverse
# proxy on rue; see docs/DEV_SERVER_SETUP.md §7).
# -----------------------------------------------------------------------------
# SPRING_PROFILES_ACTIVE=prod
# JWT_SECRET=<64-char-hex-secret>
# APP_BASE_URL=https://brazen.1lpro.com
# CORS_ALLOWED_ORIGINS=https://brazen.1lpro.com
# APP_MEDIA_ROOT=/app/media
# SMTP_HOST=<your-smtp-host>
# SMTP_PORT=587
# SMTP_USERNAME=...
# SMTP_PASSWORD=...
# MAIL_FROM=noreply@brazen.1lpro.com
# NEXT_PUBLIC_API_URL=https://brazen.1lpro.com/api
# BACKEND_URL=http://backend:8080
